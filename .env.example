# Токен бота из https://discord.com/developers/applications
DISCORD_TOKEN=

# ID канала, в котором НЕ-администраторы могут пользоваться командами экономики
# (!bal, !transfer, !lb). Админы могут вызывать команды где угодно.
# Чтобы скопировать ID: включите Режим разработчика в Discord -> ПКМ по каналу -> Копировать ID.
ECONOMY_CHANNEL_ID=

# ID роли, которая считается администраторской для бота.
# Любой участник с этой ролью получает права админа бота (!gb, !rb, обход канала),
# даже если у него нет права "Администратор" в самом Discord.
# Право "Администратор" в Discord по-прежнему тоже даёт доступ.
# Чтобы скопировать ID: Настройки сервера -> Роли -> ПКМ по роли -> Копировать ID.
ADMIN_ROLE_ID=

# Каналы, на которые бот укажет новичку в приветствии.
# Формат: Метка:ID через запятую. Метку можно опустить (тогда будет просто ссылка).
# Бот отрисует ID как кликабельную ссылку-#канал. Можно оставить пустым и добавить позже.
# Пример: WELCOME_CHANNELS=Rules:123456789012345678, Introductions:234567890123456789
WELCOME_CHANNELS=

# Резервный канал для приветствия: если у новичка закрыты ЛС, бот напишет сюда.
# Если пусто — при закрытых ЛС новичок просто ничего не получит.
WELCOME_CHANNEL_ID=

# Канал, куда падают заявки игроков на игровые роли (для администраторов).
# Здесь бот публикует интерактивную панель: приоритеты, добавить/убрать роли, утвердить.
ADMIN_CHANNEL_ID=

# (Необязательно) ID вашего сервера. Если указан — слэш-команды появятся МГНОВЕННО.
# Если пусто — глобальная синхронизация (может занять до часа).
GUILD_ID=

# Префикс текстовых команд (по умолчанию "!")
PREFIX=!

# Путь к файлу базы данных
DB_PATH=economy.db
